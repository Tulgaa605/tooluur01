{
  "name": "water-billing-system",
  "version": "1.0.0",
  "private": true,
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node scripts/clean-next-dev.js && npx cross-env NODE_ENV=development next dev --webpack",
    "dev:3001": "node scripts/clean-next-dev.js && npx cross-env NODE_ENV=development next dev -p 3001 --webpack",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next-build',{recursive:true,force:true,maxRetries:12,retryDelay:150})}catch(e){}\" && npx cross-env NODE_ENV=development next dev --webpack",
    "build": "prisma generate && node scripts/clean-next-build-types.js && next build --webpack",
    "build:no-tsc": "prisma generate && node scripts/clean-next-build-types.js &&  NEXT_IGNORE_BUILD_ERRORS=1 next build --webpack",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "build:clean": "node -e \"try{require('fs').rmSync('.next-build',{recursive:true,force:true})}catch(e){}\" && pnpm build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"commonjs\",\"esModuleInterop\":true} prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"commonjs\",\"esModuleInterop\":true} prisma/seed.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^5.19.0",
    "ag-grid-community": "^35.0.1",
    "ag-grid-react": "^35.0.1",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.1.7",
    "pm2": "^6.0.14",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "20.19.37",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.5.8",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
