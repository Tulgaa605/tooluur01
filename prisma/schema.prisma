generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String
  code      String?
  phone     String?
  role      String   @default("USER")
  organizationId String? @db.ObjectId
  organization Organization? @relation(fields: [organizationId], references: [id])
  year      Int      @default(2026)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipeFeesCreated            PipeFee[]            @relation("PipeFeeCreatedBy")
  pipeFeesUpdated            PipeFee[]            @relation("PipeFeeUpdatedBy")
  organizationsCreated       Organization[]     @relation("OrganizationCreatedBy")
  organizationsUpdated       Organization[]     @relation("OrganizationUpdatedBy")
  organizationTariffsCreated OrganizationTariff[] @relation("OrgTariffCreatedBy")
  organizationTariffsUpdated OrganizationTariff[] @relation("OrgTariffUpdatedBy")
  metersCreated              Meter[]            @relation("MeterCreatedBy")
  metersUpdated              Meter[]            @relation("MeterUpdatedBy")
  meterReadingsCreated       MeterReading[]     @relation("MeterReadingCreatedBy")
  meterReadingsUpdated       MeterReading[]     @relation("MeterReadingUpdatedBy")
  officePipeFeesCreated      OfficePipeFee[]    @relation("OfficePipeCreatedBy")
  officePipeFeesUpdated      OfficePipeFee[]    @relation("OfficePipeUpdatedBy")
  categoryTariffsCreated     CategoryTariff[]   @relation("CategoryTariffCreatedBy")
  categoryTariffsUpdated     CategoryTariff[]   @relation("CategoryTariffUpdatedBy")

  @@map("users")
}

model Organization {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String   @unique
  ovog            String?
  code            String?
  address         String?
  phone           String?
  email           String?
  connectionNumber String?
  category        String   @default("HOUSEHOLD")
  baseCleanFee    Float    @default(0)
  baseDirtyFee    Float    @default(0)
  year            Int      @default(2026)
  managedByOrganizationId String? @db.ObjectId
  managedByOrganization     Organization?  @relation("ManagedCustomers", fields: [managedByOrganizationId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  managedCustomers          Organization[] @relation("ManagedCustomers")
  users           User[]
  meters          Meter[]
  readings        MeterReading[]
  tariffs         OrganizationTariff[]
  officePipeFees OfficePipeFee[]
  createdByUserId String?  @db.ObjectId
  updatedByUserId String?  @db.ObjectId
  createdByUser   User?    @relation("OrganizationCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?    @relation("OrganizationUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("organizations")
}

model OrganizationTariff {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])
  year           Int
  month          Int
  baseCleanFee   Float        @default(0)
  baseDirtyFee   Float        @default(0)
  cleanPerM3     Float        @default(0)
  dirtyPerM3     Float        @default(0)
  /// Дулааны суурь (₮/сар)
  heatBaseFee    Float        @default(0)
  /// Төсөвт / ААН: ₮/м³
  heatPerM3      Float        @default(0)
  /// Айл өрх: ₮/м²
  heatPerM2      Float        @default(0)
  createdByUserId String?     @db.ObjectId
  updatedByUserId String?     @db.ObjectId
  createdByUser   User?       @relation("OrgTariffCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?       @relation("OrgTariffUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, year, month])
  @@map("organization_tariffs")
}

model Meter {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  meterNumber    String        @unique
  organizationId String        @db.ObjectId
  organization   Organization  @relation(fields: [organizationId], references: [id])
  year           Int           @default(2026)
  /// WATER | HEAT | WATER_HEAT — ус, дулаан, эсвэл хоёуланг нь тооцно.
  billingMode    String        @default("WATER")
  /// NORMAL | DAMAGED | REPLACED — хоосон/null = хэвийн (хуучин баримттай нийцэх).
  serviceStatus  String?
  /// HEAT / WATER_HEAT: дулааны м³/м² — заалт оруулахад анхны утга; тоолуур бүртгэхэд заавал бөглөнө.
  defaultHeatUsage Float?
  /// Ус / Ус+дулаан: BOTH | CLEAN_ONLY | DIRTY_ONLY — аль төлбөрийг тооцох (null = BOTH).
  waterChargeSplit String?
  readings       MeterReading[]
  createdByUserId String?      @db.ObjectId
  updatedByUserId String?      @db.ObjectId
  createdByUser   User?        @relation("MeterCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?        @relation("MeterUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("meters")
}

model MeterReading {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  meterId        String       @db.ObjectId
  meter          Meter        @relation(fields: [meterId], references: [id])
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id])
  month          Int
  year           Int
  startValue     Float
  endValue       Float
  /// Дулааны хэрэглээ (м³/м²). HEAT болон WATER_HEAT дээр UI-гээс орж хадгалагдана.
  heatUsage      Float        @default(0)
  usage          Float
  baseClean      Float        @default(0)
  baseDirty      Float        @default(0)
  cleanPerM3     Float        @default(0)
  dirtyPerM3     Float        @default(0)
  cleanAmount    Float        @default(0)
  dirtyAmount    Float        @default(0)
  heatBase       Float        @default(0)
  heatPerM3      Float        @default(0)
  heatPerM2      Float        @default(0)
  heatAmount     Float        @default(0)
  subtotal       Float        @default(0)
  vat            Float        @default(0)
  total          Float        @default(0)
  approved       Boolean      @default(false)
  approvedBy     String?
  approvedAt     DateTime?
  /// Хуучин баримт: зөвхөн текстээр хадгалсан user id (шүүлтэд ашиглана).
  createdBy      String
  createdByUserId String?     @db.ObjectId
  updatedByUserId String?     @db.ObjectId
  createdByUser   User?       @relation("MeterReadingCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?       @relation("MeterReadingUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([meterId, month, year])
  @@index([organizationId, year, month])
  @@map("meter_readings")
}

model PipeFee {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  diameterMm   Int
  baseCleanFee Float    @default(0)
  baseDirtyFee Float    @default(0)
  createdByUserId String? @db.ObjectId
  updatedByUserId String? @db.ObjectId
  createdByUser   User?  @relation("PipeFeeCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?  @relation("PipeFeeUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([diameterMm])
  @@map("pipe_fees")
}

// Албан байгууллага (нягтлан) бүр өөрийн шугамын суурь хураамжийг тусад нь тохируулна.
model OfficePipeFee {
  id                   String       @id @default(auto()) @map("_id") @db.ObjectId
  officeOrganizationId String       @db.ObjectId
  officeOrganization   Organization @relation(fields: [officeOrganizationId], references: [id])
  diameterMm           Int
  baseCleanFee         Float        @default(0)
  baseDirtyFee         Float        @default(0)
  createdByUserId String?          @db.ObjectId
  updatedByUserId String?          @db.ObjectId
  createdByUser   User?            @relation("OfficePipeCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?            @relation("OfficePipeUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([officeOrganizationId, diameterMm])
  @@map("office_pipe_fees")
}

/// Төрлийн (category) тариф — `category_tariffs` цуглуулга.
model CategoryTariff {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  category        String   @unique
  baseCleanFee    Float    @default(0)
  baseDirtyFee    Float    @default(0)
  cleanPerM3      Float    @default(0)
  dirtyPerM3      Float    @default(0)
  heatBaseFee     Float    @default(0)
  heatPerM3       Float    @default(0)
  heatPerM2       Float    @default(0)
  createdByUserId String?  @db.ObjectId
  updatedByUserId String?  @db.ObjectId
  createdByUser   User?    @relation("CategoryTariffCreatedBy", fields: [createdByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedByUser   User?    @relation("CategoryTariffUpdatedBy", fields: [updatedByUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("category_tariffs")
}
